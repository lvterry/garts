generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Artwork {
  id        String   @id @default(uuid())
  keyword   String
  mood      String
  artData   String   // JSON stringified
  format    String   @default("p5") // "p5" or "svg"
  createdAt DateTime @default(now())
}
